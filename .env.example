# Backend environment variables (copy to backend/.env or set in Render)
DATABASE_URL=postgresql://neondb_owner:...@...neon.tech/neondb?sslmode=require
JWT_SECRET=your-very-secure-secret-min-64-chars
ALLOWED_ORIGINS=https://shop.helvino.org,http://localhost:3000

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://api.helvino.org/api/v1/payments/mpesa/callback
MPESA_ENV=sandbox  # change to production when live

# Flutterwave / Card Payments
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=
FLW_CALLBACK_URL=https://shop.helvino.org/payment/verify

# Africa's Talking (SMS)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=HELVINO

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase (push notifications)
FIREBASE_CREDENTIALS_FILE=firebase-service-account.json

# Email
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=info@helvino.org
MAIL_PASSWORD=
